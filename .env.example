# ========== Postgres local (docker-compose) ==========
# Puerto del host donde se expone Postgres. Cambia esto si tienes otro
# Postgres corriendo en 5432 (ej. pgAdmin local).
POSTGRES_HOST_PORT=5467

# ========== Backend (Spring Boot perfil dev) ==========
# JWT secret de desarrollo. En prod esto viene de AWS Secrets Manager.
JWT_SECRET=dev-secret-change-me-in-prod-this-must-be-32-bytes-or-more

# ========== Pasarela de pagos (Semana 2) ==========
# Token de sandbox de MercadoPago. Pídelo en https://www.mercadopago.com.pe/developers
MERCADOPAGO_ACCESS_TOKEN=

# Secret del webhook de MercadoPago. Lo encontrás en el panel de
# integración → Webhooks → Configurar firma. En dev déjalo vacío y la
# validación de firma se relaja con warning. En producción es obligatorio.
MERCADOPAGO_WEBHOOK_SECRET=

# ========== Firebase Cloud Messaging (Semana 2) ==========
# JSON del service account, codificado en base64.
# En dev déjalo vacío y FIREBASE_ENABLED=false.
FIREBASE_CREDENTIALS_JSON=
FIREBASE_ENABLED=false

# ========== AWS S3 (Semana 3) ==========
# En dev usamos LocalStorage, no necesitas estas.
AWS_REGION=
AWS_S3_BUCKET=

# ========== Correo transaccional / SMTP (Semana 3) ==========
# En dev déjalo vacío: sin MAIL_HOST el servicio de correo se autodeshabilita
# y solo loguea [EMAIL DEV]. Para probar el envío real, usá un App Password de
# Gmail o un buzón de pruebas (Mailtrap). En prod las credenciales vienen de
# AWS Secrets Manager. Ver ADR-0021.
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@queueless.local
MAIL_FROM_NAME=QueueLess
