# .npmrc — Configuración de seguridad para pnpm en QueueLess
#
# Este archivo configura pnpm (y cualquier otra herramienta que lo lea) con
# defaults seguros frente a supply chain attacks del registry de paquetes.
#
# Aplica tanto a web/ como a mobile/ si lo copiás a cada uno, o se puede
# poner en la raíz del repo si querés que aplique global.

# =============================================================================
# 1. BLOQUEAR SCRIPTS DE LIFECYCLE (postinstall, preinstall, etc.)
# =============================================================================
# Razón: el vector de ataque más común en supply chain attacks es el script
# postinstall de un paquete malicioso. Bloquearlos por default y revisarlos
# manualmente cuando algún paquete legítimo los necesite.
#
# Si un paquete falla por no ejecutar su postinstall, lo revisamos en su
# documentación y decidimos si lo aprobamos manualmente.
enable-pre-post-scripts=false
ignore-scripts=true

# =============================================================================
# 2. VERSIONES EXACTAS
# =============================================================================
# Razón: al instalar un paquete con `pnpm add <pkg>`, evitamos que pnpm
# escriba "^1.2.3" o "~1.2.3" en package.json. Quedaría "1.2.3" exacto,
# garantizando reproducibilidad y evitando actualizaciones silenciosas.
save-exact=true

# =============================================================================
# 3. LOCKFILE ESTRICTO
# =============================================================================
# Razón: pnpm-lock.yaml es la fuente de verdad. En CI y producción se debe
# instalar con --frozen-lockfile. Acá hacemos el default más conservador.
prefer-frozen-lockfile=true

# =============================================================================
# 4. REGISTRY OFICIAL EXPLÍCITO
# =============================================================================
# Razón: forzar el registry oficial evita ataques donde un .npmrc malicioso
# en un paquete podría redirigir a un mirror falso.
registry=https://registry.npmjs.org/

# =============================================================================
# 5. AUDITORÍA AUTOMÁTICA
# =============================================================================
# Razón: muestra vulnerabilidades conocidas durante install.
audit-level=moderate

# =============================================================================
# 6. NO PERMITIR DEPENDENCIAS FANTASMA
# =============================================================================
# Razón: pnpm por default ya es estricto. Esto lo refuerza: solo permitimos
# importar paquetes que estén explícitamente declarados en package.json.
# Si vemos `import X from 'lodash'` pero lodash no está en deps, falla.
strict-peer-dependencies=true

# =============================================================================
# 7. CACHE LOCAL DEL STORE
# =============================================================================
# Razón: pnpm cachea los paquetes en un store compartido. Confirma que está
# en una ubicación predecible (no en una ruta hackable de %TEMP%).
# Comentado: descomentá si querés forzar una ubicación específica.
# store-dir=~/.pnpm-store

# =============================================================================
# 8. NOTAS DE USO
# =============================================================================
# Para CI/CD (GitHub Actions):
#   pnpm install --frozen-lockfile
#
# Para añadir un paquete nuevo (proceso manual, NO Claude Code):
#   1. Revisar el paquete en https://socket.dev/ (análisis estático).
#   2. Revisar https://www.npmjs.com/package/<nombre> (mantenedor, descargas, fecha).
#   3. Verificar que no tiene `postinstall` script sospechoso en su package.json.
#   4. Recién entonces: pnpm add <nombre>
#   5. Revisar el diff de pnpm-lock.yaml antes de commitearlo.
#
# Para auditar dependencias existentes:
#   pnpm audit
#   pnpm outdated
